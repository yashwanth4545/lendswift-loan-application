{
  "name": "lendswift-loan-application",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test:e2e": "node scripts/generate-fixtures.mjs && cypress run",
    "test:e2e:open": "node scripts/generate-fixtures.mjs && cypress open",
    "test:e2e:ci": "node scripts/generate-fixtures.mjs && npm run build && node scripts/run-e2e.mjs",
    "deploy": "netlify deploy --prod --dir=dist --no-build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-checkbox": "^1.1.2",
